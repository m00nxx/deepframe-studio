{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeepFrame Studio",
  "version": "0.2.0",
  "identifier": "studio.deepframe.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173/index.html",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DeepFrame Studio",
        "width": 1440,
        "height": 840,
        "minWidth": 1180,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' http://127.0.0.1:* http://localhost:*; img-src 'self' asset: http://asset.localhost; media-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "externalBin": [
      "binaries/deepframe-sidecar"
    ]
  }
}
